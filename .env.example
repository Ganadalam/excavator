# ─────────────────────────────────────────────────────────────
#  EX-MGMT Pro — Environment Variables
#  Copy to .env.local for local dev. NEVER commit .env.local.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
#
# [로컬 개발] SQLite:
#   DATABASE_URL="file:./prisma/exmgmt.db"
#
# [Vercel + Supabase] Supabase 대시보드 → Settings → Database
#   → Connection string → Transaction (포트 6543) 복사:
#   DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres"
#

DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres"

# ── JWT Secret ────────────────────────────────────────────────
# 생성: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="jljssljkknldsijlksnsdioddhlksdflknljkfs"

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
